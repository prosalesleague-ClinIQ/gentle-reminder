{
  "expo": {
    "name": "Gentle Reminder",
    "slug": "gentle-reminder",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "gentlereminder",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gentlereminder.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Gentle Reminder needs microphone access to record your stories and voice responses.",
        "NSSpeechRecognitionUsageDescription": "Gentle Reminder uses speech recognition to understand your responses."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.gentlereminder.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Gentle Reminder needs microphone access to record your stories."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
