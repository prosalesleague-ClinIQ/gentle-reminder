{
  "name": "@gentle-reminder/api",
  "version": "0.1.0",
  "private": true,
  "description": "Gentle Reminder backend API service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --detectOpenHandles",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gentle-reminder/auth": "*",
    "@gentle-reminder/cognitive-engine": "*",
    "@gentle-reminder/database": "*",
    "@gentle-reminder/shared-types": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "moduleNameMapper": {
      "^@gentle-reminder/database$": "<rootDir>/../../packages/database/src",
      "^@gentle-reminder/auth$": "<rootDir>/../../packages/auth/src",
      "^@gentle-reminder/shared-types$": "<rootDir>/../../packages/shared-types/src",
      "^@gentle-reminder/cognitive-engine$": "<rootDir>/../../packages/cognitive-engine/src",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "esModuleInterop": true,
            "allowJs": true,
            "strict": true,
            "resolveJsonModule": true
          }
        }
      ]
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
